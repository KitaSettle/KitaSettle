# KitaSettle Alpha — Environment Variables
# Copy to .env.local for local development, or configure in your hosting provider.

# Runtime
NODE_ENV=development

# Public (safe for browser)
NEXT_PUBLIC_APP_NAME=KitaSettle Alpha
NEXT_PUBLIC_APP_ENV=alpha
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (optional for local dev — mock data used when missing or placeholder)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: UUID of your auth user for server-side scripts (brain:test, research:test)
SUPABASE_SYSTEM_USER_ID=

# Optional: OpenAI (Sprint 9 — mock fallback when missing)
OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o-mini

# Optional: GLM (Zhipu/Z.ai) — used instead of OpenAI when set, via the same
# OpenAI-compatible client. Takes priority over OPENAI_API_KEY when both are set.
# GLM_API_KEY=your-glm-api-key
# GLM_MODEL=glm-4.6
# GLM_BASE_URL=https://api.z.ai/api/paas/v4/

# Optional: Google OAuth (Milestone 4 — Executive Connect)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback

# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Future search / crawl providers (optional — not used in Alpha)
# TAVILY_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=

# Mission Control (Sprint 1 — admin only, comma-separated)
# ADMIN_USER_IDS=
# ADMIN_EMAILS=you@company.com

# Cron auth: required for the proactive daily-brief job (/api/cron/daily-brief)
# to authenticate scheduled requests from Vercel Cron. Generate any random string.
# CRON_SECRET=

# Without valid Supabase vars, KitaSettle runs in mock data mode (see /api/health).
