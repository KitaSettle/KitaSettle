# KitaSettle Alpha — Environment Variables
# Copy to .env.local for local development, or configure in your hosting provider.

# Runtime
NODE_ENV=development

# Public (safe for browser)
NEXT_PUBLIC_APP_NAME=KitaSettle Alpha
NEXT_PUBLIC_APP_ENV=alpha
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future AI providers (optional — not used in Alpha mock mode)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Future search / crawl providers (optional — not used in Alpha)
# TAVILY_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=

# Future database / vector storage (optional — not used in Alpha)
# DATABASE_URL=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
